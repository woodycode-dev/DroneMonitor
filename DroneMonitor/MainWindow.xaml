<Window x:Class="DroneMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="드론 모니터링 대시보드" Height="500" Width="800"
        Background="#1E1E2E">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 & 상태 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="🚁 드론 모니터링 대시보드"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#CDD6F4"/>
            <TextBlock Text="{Binding State}"
                       FontSize="14" Foreground="#A6E3A1"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 데이터 카드 그리드 -->
        <UniformGrid Grid.Row="1" Rows="2" Columns="3" >

            <!-- 배터리 -->
            <Border Background="#313244" CornerRadius="10" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔋 배터리" Foreground="#CDD6F4" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Battery, StringFormat='{}{0}%'}"
                               Foreground="#A6E3A1" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 고도 -->
            <Border Background="#313244" CornerRadius="10" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📡 고도" Foreground="#CDD6F4" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Altitude, StringFormat='{}{0:F1}m'}"
                               Foreground="#89B4FA" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 속도 -->
            <Border Background="#313244" CornerRadius="10" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="💨 속도" Foreground="#CDD6F4" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Speed, StringFormat='{}{0:F1}m/s'}"
                               Foreground="#FAB387" FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 위도 -->
            <Border Background="#313244" CornerRadius="10" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📍 위도" Foreground="#CDD6F4" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Latitude, StringFormat='{}{0:F6}'}"
                               Foreground="#F5C2E7" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 경도 -->
            <Border Background="#313244" CornerRadius="10" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📍 경도" Foreground="#CDD6F4" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Longitude, StringFormat='{}{0:F6}'}"
                               Foreground="#F5C2E7" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 상태 -->
            <Border Background="#313244" CornerRadius="10" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📶 상태" Foreground="#CDD6F4" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding State}"
                               Foreground="#A6E3A1" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- 버튼 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="연결" Command="{Binding ConnectCommand}"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    FontWeight="Bold" Padding="24,10"
                    Margin="0,0,10,0" BorderThickness="0"/>
            <Button Content="해제" Command="{Binding DisconnectCommand}"
                    Background="#F38BA8" Foreground="#1E1E2E"
                    FontWeight="Bold" Padding="24,10"
                    BorderThickness="0"/>
        </StackPanel>

    </Grid>
</Window>